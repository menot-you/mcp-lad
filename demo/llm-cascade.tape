# VHS tape — lad LLM kick-in cascade demo.
# Render: cd demo && vhs llm-cascade.tape

Output llm-cascade.gif
Output llm-cascade.mp4
Output llm-cascade.webm

Set FontSize 15
Set Width 1200
Set Height 820
Set Padding 30
Set Theme "TokyoNight"
Set TypingSpeed 40ms

Sleep 700ms
Type "./llm-cascade.sh"
Sleep 500ms
Enter

Sleep 16s
