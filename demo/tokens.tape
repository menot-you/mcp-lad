# VHS tape — token economy demo for lad.
# Render: cd demo && vhs tokens.tape

Output tokens.gif
Output tokens.mp4
Output tokens.webm

Set FontSize 18
Set Width 1100
Set Height 700
Set Padding 30
Set Theme "TokyoNight"
Set TypingSpeed 40ms

Sleep 800ms
Type "./tokens.sh"
Sleep 400ms
Enter

Sleep 10s
